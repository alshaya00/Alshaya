modules = ["nodejs-20", "web", "nix", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-25_05"

[env]
NODE_OPTIONS = "--max-old-space-size=2048"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dev Server"

[[workflows.workflow]]
name = "Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]

[agent]
expertMode = true
integrations = ["resend:1.0.0", "google-sheet:1.0.0"]
