# Al-Shaye Family Tree - Environment Variables
# Copy this file to .env.local and fill in your values
#
# Required = must be set for app to function
# Production = must be set in production, optional in dev
# Optional = has sensible defaults or enables extra features

# ===========================================
# Database (Required)
# ===========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/alshaye_family_tree?sslmode=require"

# Production database URL (only for sync scripts)
# PRODUCTION_DATABASE_URL="postgresql://user:password@prod-host:5432/alshaye_prod?sslmode=require"

# ===========================================
# Authentication & Security (Production Required)
# ===========================================
# Secret for JWT tokens - generate with: openssl rand -base64 32
# Must be at least 32 characters
JWT_SECRET="your-jwt-secret-here-at-least-32-characters-long"

# Secret for encrypting sensitive data - generate with: openssl rand -base64 32
# Must be at least 32 characters
ENCRYPTION_SECRET="your-encryption-secret-at-least-32-characters"

# Optional: Custom salt for encryption (has default fallback)
# ENCRYPTION_SALT="custom-salt"

# Session duration (in days)
SESSION_DURATION_DAYS=7
REMEMBER_ME_DURATION_DAYS=30

# ===========================================
# Admin Account (Production Required)
# ===========================================
# Initial admin credentials - CHANGE BEFORE DEPLOYING!
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="YourSecurePassword123!"

# Admin access code (required in production)
ADMIN_ACCESS_CODE=""

# ===========================================
# Access Control (Production Required)
# ===========================================
# Public access code for the family tree app
NEXT_PUBLIC_ACCESS_CODE=""

# ===========================================
# Application URLs (Required)
# ===========================================
# Public-facing application URL (used client-side)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Base URL (used server-side for links, callbacks, OAuth redirects)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ===========================================
# Node Environment (Optional - defaults to development)
# ===========================================
NODE_ENV=development

# ===========================================
# Email Service (Optional - defaults to none)
# ===========================================
# Provider: resend, sendgrid, mailgun, smtp, or none
EMAIL_PROVIDER=none
EMAIL_FROM_ADDRESS="noreply@example.com"
EMAIL_FROM_NAME="Al-Shaye Family Tree"

# Resend (recommended)
RESEND_API_KEY=""

# SendGrid
# SENDGRID_API_KEY=""

# Mailgun
# MAILGUN_API_KEY=""
# MAILGUN_DOMAIN=""

# SMTP (for custom email servers)
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_SECURE=true

# ===========================================
# SMS / OTP Service (Optional - defaults to none)
# ===========================================
# Provider: twilio, vonage, messagebird, or none
OTP_PROVIDER=none
OTP_FROM_NUMBER=""

# Twilio
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_VERIFY_SERVICE_SID=""

# Vonage (Nexmo)
# VONAGE_API_KEY=""
# VONAGE_API_SECRET=""

# MessageBird
# MESSAGEBIRD_API_KEY=""

# ===========================================
# OAuth Providers (Optional)
# ===========================================
# Google OAuth
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# ===========================================
# Google Services (Optional - for export features)
# ===========================================
# Google Sheets / Drive export
# GOOGLE_ACCESS_TOKEN=""
# GOOGLE_CLIENT_EMAIL=""
# GOOGLE_PRIVATE_KEY=""

# ===========================================
# GitHub Backup (Optional)
# ===========================================
# GITHUB_TOKEN=""
# GITHUB_ACCESS_TOKEN=""

# ===========================================
# External Storage (Optional)
# ===========================================
# AWS S3 for image uploads
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_S3_REGION=""

# Cloudinary for image uploads
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ===========================================
# Redis (Optional - for production caching/rate-limiting)
# ===========================================
# REDIS_URL="redis://localhost:6379"

# ===========================================
# Development / Testing
# ===========================================
# Enable test mode for email/SMS (no actual messages sent)
TEST_MODE=true
