generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FamilyMember {
  id                   String                      @id
  firstName            String
  fatherName           String?
  grandfatherName      String?
  greatGrandfatherName String?
  familyName           String                      @default("آل شايع")
  fatherId             String?
  gender               String
  birthYear            Int?
  birthCalendar        String                      @default("GREGORIAN")
  deathYear            Int?
  deathCalendar        String                      @default("GREGORIAN")
  sonsCount            Int                         @default(0)
  daughtersCount       Int                         @default(0)
  generation           Int                         @default(1)
  branch               String?
  fullNameAr           String?
  fullNameEn           String?
  lineageBranchId      String?
  lineageBranchName    String?
  subBranchId          String?
  subBranchName        String?
  lineagePath          String?
  phone                String?
  city                 String?
  status               String                      @default("Living")
  photoUrl             String?
  biography            String?
  occupation           String?
  email                String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  createdBy            String?
  lastModifiedBy       String?
  version              Int                         @default(1)
  deletedAt            DateTime?
  deletedBy            String?
  deletedReason        String?
  breastfedBy          BreastfeedingRelationship[] @relation("BreastfedChild")
  milkChildren         BreastfeedingRelationship[] @relation("MilkFatherRelation")
  nursedChildren       BreastfeedingRelationship[] @relation("NurseRelation")
  changeHistory        ChangeHistory[]
  duplicateOf          DuplicateFlag[]             @relation("DuplicateSource")
  duplicatedBy         DuplicateFlag[]             @relation("DuplicateTarget")
  father               FamilyMember?               @relation("ParentChild", fields: [fatherId], references: [id])
  children             FamilyMember[]              @relation("ParentChild")
  photos               MemberPhoto[]

  @@index([generation])
  @@index([branch])
  @@index([gender])
  @@index([fatherId])
  @@index([status])
  @@index([firstName])
  @@index([lineageBranchId])
  @@index([subBranchId])
  @@index([deletedAt])
  @@index([fatherId, deletedAt])
}

model ChangeHistory {
  id            String       @id @default(cuid())
  memberId      String
  fieldName     String
  oldValue      String?
  newValue      String?
  changeType    String
  changedBy     String
  changedByName String
  changedAt     DateTime     @default(now())
  batchId       String?
  fullSnapshot  String?
  reason        String?
  ipAddress     String?
  member        FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([changedAt])
  @@index([changedBy])
  @@index([batchId])
  @@index([changeType])
}

model Snapshot {
  id            String   @id @default(cuid())
  name          String
  description   String?
  treeData      String
  memberCount   Int
  createdBy     String
  createdByName String
  createdAt     DateTime @default(now())
  snapshotType  String   @default("MANUAL")

  @@index([createdAt])
  @@index([snapshotType])
}

model DuplicateFlag {
  id             String       @id @default(cuid())
  sourceMemberId String
  targetMemberId String
  matchScore     Float
  matchReasons   String
  status         String       @default("PENDING")
  resolvedBy     String?
  resolvedAt     DateTime?
  resolution     String?
  detectedAt     DateTime     @default(now())
  detectedBy     String       @default("SYSTEM")
  sourceMember   FamilyMember @relation("DuplicateSource", fields: [sourceMemberId], references: [id], onDelete: Cascade)
  targetMember   FamilyMember @relation("DuplicateTarget", fields: [targetMemberId], references: [id], onDelete: Cascade)

  @@unique([sourceMemberId, targetMemberId])
  @@index([status])
  @@index([matchScore])
}

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  passwordHash         String
  nameArabic           String
  nameEnglish          String?
  phone                String?
  avatarUrl            String?
  role                 String         @default("MEMBER")
  status               String         @default("PENDING")
  linkedMemberId       String?        @unique
  assignedBranch       String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  lastLoginAt          DateTime?
  emailVerifiedAt      DateTime?
  twoFactorEnabled     Boolean        @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String?
  phoneVerified        Boolean        @default(false)
  failedLoginAttempts  Int            @default(0)
  lockedUntil          DateTime?
  verificationStatus   String         @default("UNVERIFIED")
  verifiedAt           DateTime?
  verifiedBy           String?
  verifierName         String?
  verificationNotes    String?
  accessRequest        AccessRequest?
  activityLogs         ActivityLog[]
  invitesSent          Invite[]       @relation("InviteSender")
  inviteUsed           Invite?        @relation("InviteUsed")
  notifications        Notification[]
  otpCodes             OtpCode[]
  sessions             Session[]
  loginHistory         LoginHistory[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([verificationStatus])
}

model OtpCode {
  id        String    @id @default(cuid())
  userId    String?
  phone     String
  code      String
  purpose   String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([phone, code])
  @@index([expiresAt])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  rememberMe   Boolean  @default(false)
  ipAddress    String?
  userAgent    String?
  deviceName   String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model LoginHistory {
  id            String   @id @default(cuid())
  userId        String
  loginAt       DateTime @default(now())
  success       Boolean
  ipAddress     String?
  userAgent     String?
  deviceName    String?
  failureReason String?
  method        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loginAt])
  @@index([userId, success])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  email     String
  role      String    @default("MEMBER")
  branch    String?
  sentById  String
  expiresAt DateTime
  usedAt    DateTime?
  usedById  String?   @unique
  message   String?
  createdAt DateTime  @default(now())
  sentBy    User      @relation("InviteSender", fields: [sentById], references: [id])
  usedBy    User?     @relation("InviteUsed", fields: [usedById], references: [id])

  @@index([code])
  @@index([email])
  @@index([sentById])
}

model AccessRequest {
  id               String    @id @default(cuid())
  email            String
  nameArabic       String
  nameEnglish      String?
  phone            String?
  gender           String?
  claimedRelation  String
  relatedMemberId  String?
  relationshipType String?
  parentMemberId   String?
  message          String?
  passwordHash     String?
  status           String    @default("PENDING")
  reviewedById     String?
  reviewedAt       DateTime?
  reviewNote       String?
  userId           String?   @unique
  approvedRole     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User?     @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([status])
}

model PasswordReset {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}

model EmailVerification {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}

model PermissionMatrix {
  id          String   @id @default("default")
  permissions String   @default("{}")
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model UserPermissionOverride {
  id            String   @id @default(cuid())
  userId        String
  permissionKey String
  allowed       Boolean
  setBy         String
  setAt         DateTime @default(now())
  reason        String?

  @@unique([userId, permissionKey])
  @@index([userId])
}

model SiteSettings {
  id                             String   @id @default("default")
  familyNameArabic               String   @default("آل شايع")
  familyNameEnglish              String   @default("Al-Shaye")
  taglineArabic                  String   @default("نحفظ إرثنا، نربط أجيالنا")
  taglineEnglish                 String   @default("Preserving Our Legacy, Connecting Generations")
  logoUrl                        String?
  defaultLanguage                String   @default("ar")
  sessionDurationDays            Int      @default(7)
  rememberMeDurationDays         Int      @default(30)
  allowSelfRegistration          Boolean  @default(true)
  requireEmailVerification       Boolean  @default(false)
  requireApprovalForRegistration Boolean  @default(true)
  maxLoginAttempts               Int      @default(5)
  lockoutDurationMinutes         Int      @default(15)
  require2FAForAdmins            Boolean  @default(false)
  minPasswordLength              Int      @default(8)
  allowGuestPreview              Boolean  @default(true)
  guestPreviewMemberCount        Int      @default(20)
  updatedAt                      DateTime @updatedAt
}

model PrivacySettings {
  id                   String   @id @default("default")
  profileVisibility    String   @default("{\"GUEST\":false,\"MEMBER\":true,\"BRANCH_LEADER\":true,\"ADMIN\":true,\"SUPER_ADMIN\":true}")
  showPhoneToRoles     String   @default("[\"ADMIN\",\"SUPER_ADMIN\"]")
  showEmailToRoles     String   @default("[\"ADMIN\",\"SUPER_ADMIN\"]")
  showBirthYearToRoles String   @default("[\"MEMBER\",\"BRANCH_LEADER\",\"ADMIN\",\"SUPER_ADMIN\"]")
  showAgeForLiving     Boolean  @default(false)
  showOccupation       Boolean  @default(true)
  showCity             Boolean  @default(true)
  showBiography        Boolean  @default(true)
  showPhotosToRoles    String   @default("[\"MEMBER\",\"BRANCH_LEADER\",\"ADMIN\",\"SUPER_ADMIN\"]")
  showDeathYear        Boolean  @default(true)
  showFullDeathDate    Boolean  @default(false)
  updatedAt            DateTime @updatedAt
}

model SystemConfig {
  id                      String   @id @default("default")
  defaultLanguage         String   @default("ar")
  dateFormat              String   @default("DD/MM/YYYY")
  treeDisplayMode         String   @default("vertical")
  showDeceasedMembers     Boolean  @default(true)
  minBirthYear            Int      @default(1400)
  maxBirthYear            Int      @default(2025)
  requirePhone            Boolean  @default(false)
  requireEmail            Boolean  @default(false)
  allowDuplicateNames     Boolean  @default(true)
  sessionTimeout          Int      @default(60)
  maxLoginAttempts        Int      @default(20)
  requireStrongAccessCode Boolean  @default(false)
  enableBranchEntries     Boolean  @default(true)
  enablePublicRegistry    Boolean  @default(true)
  enableExport            Boolean  @default(true)
  enableImport            Boolean  @default(true)
  autoBackup              Boolean  @default(true)
  autoBackupInterval      Int      @default(24)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model ActivityLog {
  id           String   @id @default(cuid())
  userId       String?
  userEmail    String?
  userName     String?
  action       String
  category     String
  targetType   String?
  targetId     String?
  targetName   String?
  details      String?
  ipAddress    String?
  userAgent    String?
  success      Boolean  @default(true)
  errorMessage String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([category])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  titleAr   String
  titleEn   String
  messageAr String
  messageEn String
  linkUrl   String?
  linkType  String?
  linkId    String?
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Admin {
  id               String         @id @default(cuid())
  name             String
  email            String         @unique
  accessCode       String
  role             String         @default("EDITOR")
  permissions      String
  isActive         Boolean        @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdBy        String?
  migratedToUserId String?
  sessions         AdminSession[]

  @@index([email])
  @@index([isActive])
}

model AdminSession {
  id             String   @id @default(cuid())
  adminId        String
  token          String   @unique
  expiresAt      DateTime
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())
  admin          Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminId])
  @@index([expiresAt])
}

model SearchHistory {
  id              String   @id @default(cuid())
  userId          String?
  sessionId       String?
  query           String
  searchType      String   @default("member")
  filters         String?
  resultsCount    Int      @default(0)
  clickedResultId String?
  ipAddress       String?
  userAgent       String?
  searchedAt      DateTime @default(now())

  @@index([userId])
  @@index([query])
  @@index([searchedAt])
  @@index([searchType])
}

model ImportJob {
  id                  String    @id @default(cuid())
  fileName            String
  fileType            String
  totalRecords        Int
  status              String    @default("PENDING")
  processedCount      Int       @default(0)
  successCount        Int       @default(0)
  errorCount          Int       @default(0)
  conflictCount       Int       @default(0)
  conflicts           String?
  conflictResolutions String?
  importedIds         String?
  errorLog            String?
  importedBy          String
  importedByName      String
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  snapshotId          String?

  @@index([status])
  @@index([importedBy])
}

model ExportJob {
  id             String   @id @default(cuid())
  format         String
  fileName       String
  memberCount    Int
  fieldsIncluded String
  filters        String?
  exportedBy     String
  exportedByName String
  exportedAt     DateTime @default(now())
  fileSize       Int?
  downloadUrl    String?

  @@index([exportedBy])
  @@index([exportedAt])
}

model PendingMember {
  id                   String    @id @default(cuid())
  firstName            String
  fatherName           String?
  grandfatherName      String?
  greatGrandfatherName String?
  familyName           String    @default("آل شايع")
  proposedFatherId     String?
  gender               String
  birthYear            Int?
  birthCalendar        String    @default("GREGORIAN")
  generation           Int       @default(1)
  branch               String?
  fullNameAr           String?
  fullNameEn           String?
  phone                String?
  city                 String?
  status               String    @default("Living")
  occupation           String?
  email                String?
  submittedVia         String?
  submittedAt          DateTime  @default(now())
  reviewStatus         String    @default("PENDING")
  reviewedBy           String?
  reviewedAt           DateTime?
  reviewNotes          String?
  approvedMemberId     String?

  @@index([reviewStatus])
  @@index([branch])
}

model BranchEntryLink {
  id             String    @id @default(cuid())
  token          String    @unique
  branchName     String
  branchHeadId   String
  branchHeadName String
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  maxUses        Int?
  useCount       Int       @default(0)
  createdBy      String
  createdAt      DateTime  @default(now())

  @@index([token])
  @@index([isActive])
}

model ApiServiceConfig {
  id                       String   @id @default("default")
  emailProvider            String   @default("none")
  emailApiKey              String?
  emailFromAddress         String?
  emailFromName            String?
  smtpHost                 String?
  smtpPort                 Int?
  smtpUser                 String?
  smtpPassword             String?
  smtpSecure               Boolean  @default(true)
  otpProvider              String   @default("none")
  otpApiKey                String?
  otpApiSecret             String?
  otpFromNumber            String?
  enableEmailNotifications Boolean  @default(false)
  enableSMSNotifications   Boolean  @default(false)
  testMode                 Boolean  @default(true)
  updatedAt                DateTime @updatedAt
  updatedBy                String?
}

model EmailLog {
  id                String    @id @default(cuid())
  to                String
  from              String
  subject           String
  templateName      String?
  templateData      String?
  status            String    @default("PENDING")
  provider          String
  providerMessageId String?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  sentAt            DateTime?

  @@index([to])
  @@index([status])
  @@index([createdAt])
}

model Broadcast {
  id               String               @id @default(cuid())
  titleAr          String
  titleEn          String?
  contentAr        String
  contentEn        String?
  type             String               @default("ANNOUNCEMENT")
  meetingDate      DateTime?
  meetingLocation  String?
  meetingUrl       String?
  rsvpRequired     Boolean              @default(false)
  rsvpDeadline     DateTime?
  targetAudience   String               @default("ALL")
  targetBranch     String?
  targetGeneration Int?
  targetMemberIds  String?
  status           String               @default("DRAFT")
  scheduledAt      DateTime?
  sentAt           DateTime?
  totalRecipients  Int                  @default(0)
  sentCount        Int                  @default(0)
  failedCount      Int                  @default(0)
  openCount        Int                  @default(0)
  rsvpYesCount     Int                  @default(0)
  rsvpNoCount      Int                  @default(0)
  rsvpMaybeCount   Int                  @default(0)
  createdBy        String
  createdByName    String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  recipients       BroadcastRecipient[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([scheduledAt])
}

model BroadcastRecipient {
  id              String    @id @default(cuid())
  broadcastId     String
  memberId        String?
  memberName      String
  email           String
  status          String    @default("PENDING")
  sentAt          DateTime?
  errorMessage    String?
  openedAt        DateTime?
  clickedAt       DateTime?
  rsvpResponse    String?
  rsvpRespondedAt DateTime?
  rsvpNote        String?
  broadcast       Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, email])
  @@index([broadcastId])
  @@index([status])
  @@index([memberId])
}

model SmsLog {
  id                String    @id @default(cuid())
  to                String
  from              String
  message           String
  type              String    @default("OTP")
  status            String    @default("PENDING")
  provider          String
  providerMessageId String?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  sentAt            DateTime?

  @@index([to])
  @@index([status])
  @@index([createdAt])
}

model ScheduledJob {
  id              String    @id @default(cuid())
  name            String    @unique
  description     String?
  cronExpression  String
  timezone        String    @default("Asia/Riyadh")
  jobType         String
  jobConfig       String?
  isEnabled       Boolean   @default(true)
  lastRunAt       DateTime?
  lastRunStatus   String?
  lastRunDuration Int?
  lastRunError    String?
  nextRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isEnabled])
  @@index([nextRunAt])
}

model AlbumFolder {
  id            String         @id @default(cuid())
  name          String
  nameAr        String
  description   String?
  descriptionAr String?
  color         String         @default("#6366f1")
  icon          String?
  isSystem      Boolean        @default(false)
  displayOrder  Int            @default(0)
  createdBy     String?
  createdByName String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  photos        MemberPhoto[]
  pendingPhotos PendingImage[]

  @@index([isSystem])
  @@index([displayOrder])
}

model PendingImage {
  id              String       @id @default(cuid())
  imageData       String
  thumbnailData   String?
  category        String       @default("memory")
  title           String?
  titleAr         String?
  caption         String?
  captionAr       String?
  year            Int?
  memberId        String?
  memberName      String?
  taggedMemberIds String?
  uploadedBy      String?
  uploadedByName  String
  uploadedByEmail String?
  uploadedAt      DateTime     @default(now())
  ipAddress       String?
  reviewStatus    String       @default("PENDING")
  reviewedBy      String?
  reviewedByName  String?
  reviewedAt      DateTime?
  reviewNotes     String?
  approvedPhotoId String?
  folderId        String?
  folder          AlbumFolder? @relation(fields: [folderId], references: [id])

  @@index([reviewStatus])
  @@index([category])
  @@index([memberId])
  @@index([uploadedBy])
  @@index([uploadedAt])
  @@index([folderId])
}

model MemberPhoto {
  id                String        @id @default(cuid())
  imageData         String
  thumbnailData     String?
  category          String        @default("memory")
  title             String?
  titleAr           String?
  caption           String?
  captionAr         String?
  year              Int?
  memberId          String?
  taggedMemberIds   String?
  isFamilyAlbum     Boolean       @default(false)
  uploadedBy        String?
  uploadedByName    String
  originalPendingId String?
  isProfilePhoto    Boolean       @default(false)
  displayOrder      Int           @default(0)
  isPublic          Boolean       @default(true)
  folderId          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  folder            AlbumFolder?  @relation(fields: [folderId], references: [id])
  member            FamilyMember? @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([category])
  @@index([isFamilyAlbum])
  @@index([year])
  @@index([uploadedBy])
  @@index([isProfilePhoto])
  @@index([folderId])
}

model BreastfeedingRelationship {
  id                     String        @id @default(cuid())
  childId                String
  nurseId                String?
  externalNurseName      String?
  milkFatherId           String?
  externalMilkFatherName String?
  notes                  String?
  breastfeedingYear      Int?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  createdBy              String?
  child                  FamilyMember  @relation("BreastfedChild", fields: [childId], references: [id], onDelete: Cascade)
  milkFather             FamilyMember? @relation("MilkFatherRelation", fields: [milkFatherId], references: [id])
  nurse                  FamilyMember? @relation("NurseRelation", fields: [nurseId], references: [id])

  @@index([childId])
  @@index([nurseId])
  @@index([milkFatherId])
}

model FamilyJournal {
  id               String         @id @default(cuid())
  titleAr          String
  titleEn          String?
  contentAr        String
  contentEn        String?
  excerpt          String?
  category         String         @default("ORAL_HISTORY")
  tags             String?
  era              String?
  yearFrom         Int?
  yearTo           Int?
  dateDescription  String?
  location         String?
  locationAr       String?
  primaryMemberId  String?
  relatedMemberIds String?
  generation       Int?
  coverImageUrl    String?
  narrator         String?
  narratorId       String?
  source           String?
  status           String         @default("DRAFT")
  isFeatured       Boolean        @default(false)
  displayOrder     Int            @default(0)
  authorId         String?
  authorName       String
  reviewStatus     String         @default("PENDING")
  reviewedBy       String?
  reviewedAt       DateTime?
  reviewNotes      String?
  viewCount        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  mediaItems       JournalMedia[]

  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([primaryMemberId])
  @@index([generation])
  @@index([yearFrom])
  @@index([reviewStatus])
  @@index([createdAt])
}

model JournalMedia {
  id            String        @id @default(cuid())
  journalId     String
  type          String
  url           String?
  imageData     String?
  thumbnailData String?
  titleAr       String?
  titleEn       String?
  captionAr     String?
  captionEn     String?
  year          Int?
  displayOrder  Int           @default(0)
  isHero        Boolean       @default(false)
  createdAt     DateTime      @default(now())
  journal       FamilyJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@index([journalId])
  @@index([type])
}

model JournalCategory {
  id            String  @id @default(cuid())
  key           String  @unique
  nameAr        String
  nameEn        String
  descriptionAr String?
  descriptionEn String?
  icon          String?
  color         String?
  displayOrder  Int     @default(0)
  isActive      Boolean @default(true)

  @@index([key])
  @@index([displayOrder])
}

model Permission {
  id              String                  @id @default(cuid())
  key             String                  @unique
  labelAr         String
  labelEn         String
  description     String?
  descriptionAr   String?
  category        String
  displayOrder    Int                     @default(0)
  isActive        Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  rolePermissions RoleDefaultPermission[]

  @@index([key])
  @@index([category])
  @@index([displayOrder])
}

model PermissionCategory {
  id            String  @id @default(cuid())
  key           String  @unique
  labelAr       String
  labelEn       String
  descriptionAr String?
  descriptionEn String?
  icon          String?
  displayOrder  Int     @default(0)
  isActive      Boolean @default(true)

  @@index([key])
  @@index([displayOrder])
}

model RoleDefaultPermission {
  id           String     @id @default(cuid())
  role         String
  permissionId String
  allowed      Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
}

model ExportField {
  id                String  @id @default(cuid())
  key               String  @unique
  labelEn           String
  labelAr           String
  category          String
  selectedByDefault Boolean @default(false)
  displayOrder      Int     @default(0)
  isActive          Boolean @default(true)

  @@index([key])
  @@index([category])
  @@index([displayOrder])
}

model ExportFieldCategory {
  id           String  @id @default(cuid())
  key          String  @unique
  labelEn      String
  labelAr      String
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  @@index([key])
  @@index([displayOrder])
}

model Gathering {
  id              String              @id @default(cuid())
  title           String
  titleAr         String
  description     String?
  descriptionAr   String?
  date            DateTime
  endDate         DateTime?
  time            String?
  location        String?
  locationAr      String?
  locationUrl     String?
  type            String              @default("gathering")
  coverImage      String?
  organizerId     String?
  organizerName   String
  organizerNameAr String
  status          String              @default("UPCOMING")
  isPublic        Boolean             @default(true)
  createdBy       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  attendees       GatheringAttendee[]

  @@index([date])
  @@index([type])
  @@index([status])
  @@index([organizerId])
}

model GatheringAttendee {
  id          String    @id @default(cuid())
  gatheringId String
  userId      String?
  memberId    String?
  name        String
  email       String?
  rsvpStatus  String    @default("PENDING")
  rsvpNote    String?
  rsvpAt      DateTime?
  attended    Boolean   @default(false)
  attendedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  gathering   Gathering @relation(fields: [gatheringId], references: [id], onDelete: Cascade)

  @@unique([gatheringId, userId])
  @@index([gatheringId])
  @@index([userId])
  @@index([rsvpStatus])
}

model BackupConfig {
  id               String    @id @default("default")
  enabled          Boolean   @default(true)
  intervalHours    Int       @default(24)
  maxBackups       Int       @default(10)
  retentionDays    Int       @default(30)
  lastBackupAt     DateTime?
  lastBackupStatus String?
  lastBackupError  String?
  lastBackupSize   Int?
  updatedAt        DateTime  @updatedAt
  updatedBy        String?
}

model EventType {
  id           String  @id @default(cuid())
  key          String  @unique
  labelEn      String
  labelAr      String
  color        String?
  bgColor      String?
  icon         String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  @@index([key])
  @@index([displayOrder])
}

model FeatureFlag {
  id              String   @id @default("default")
  familyTree      Boolean  @default(true)
  registry        Boolean  @default(true)
  journals        Boolean  @default(true)
  gallery         Boolean  @default(true)
  gatherings      Boolean  @default(true)
  dashboard       Boolean  @default(true)
  search          Boolean  @default(true)
  branches        Boolean  @default(true)
  quickAdd        Boolean  @default(true)
  importData      Boolean  @default(true)
  exportData      Boolean  @default(true)
  treeEditor      Boolean  @default(true)
  duplicates      Boolean  @default(true)
  changeHistory   Boolean  @default(true)
  registration    Boolean  @default(true)
  invitations     Boolean  @default(true)
  accessRequests  Boolean  @default(true)
  profiles        Boolean  @default(true)
  breastfeeding   Boolean  @default(true)
  branchEntries   Boolean  @default(true)
  onboarding      Boolean  @default(true)
  imageModeration Boolean  @default(true)
  broadcasts      Boolean  @default(true)
  reports         Boolean  @default(true)
  audit           Boolean  @default(true)
  apiServices     Boolean  @default(true)
  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

model InvitationCode {
  id               String                 @id @default(cuid())
  code             String                 @unique
  linkedMemberId   String?                @unique
  linkedMemberName String?
  maxUses          Int                    @default(1)
  usedCount        Int                    @default(0)
  expiresAt        DateTime
  createdById      String
  createdByName    String
  createdAt        DateTime               @default(now())
  note             String?
  status           String                 @default("ACTIVE")
  redemptions      InvitationRedemption[]

  @@index([code])
  @@index([status])
  @@index([expiresAt])
}

model InvitationRedemption {
  id           String         @id @default(cuid())
  invitationId String
  userId       String
  userEmail    String
  userName     String
  redeemedAt   DateTime       @default(now())
  invitation   InvitationCode @relation(fields: [invitationId], references: [id])

  @@index([invitationId])
  @@index([userId])
}

model AuditLog {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  action        String
  severity      String   @default("INFO")
  userId        String?
  userName      String?
  userRole      String?
  targetType    String
  targetId      String?
  targetName    String?
  description   String
  details       Json?
  previousState Json?
  newState      Json?
  ipAddress     String?
  userAgent     String?
  sessionId     String?
  success       Boolean  @default(true)
  errorMessage  String?
  impactedIds   String?
  impactSummary Json?

  @@index([timestamp])
  @@index([action])
  @@index([userId])
  @@index([targetType])
  @@index([targetId])
  @@index([severity])
}

model Blocklist {
  id          String   @id @default(cuid())
  type        String
  value       String
  reason      String?
  blockedBy   String
  blockedByName String
  blockedAt   DateTime @default(now())
  relatedUserId String?
  relatedUserName String?

  @@unique([type, value])
  @@index([type])
  @@index([value])
  @@index([blockedAt])
}
